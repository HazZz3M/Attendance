      hideLoading();
      showMessage('Error loading teams: ' + err.message, false);
    }
  }

  // We'll rewrite the JavaScript to use fetch for all actions with a unified API.
  // Let's provide the complete updated HTML with proper fetch usage.
</script>
</body>
</html>
