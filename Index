<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
  <title>Attendance Form</title>
  <style>
    /* Same styles as before – include them here */
    /* I'll keep it concise – you can copy the full CSS from the previous snippet */
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #f0f2f5;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      margin: 0;
      padding: 16px;
    }
    .card {
      max-width: 480px;
      width: 100%;
      background: white;
      padding: 24px 20px;
      border-radius: 24px;
      box-shadow: 0 8px 28px rgba(0,0,0,0.1);
      position: relative;
    }
    h2 {
      color: #1a2b3c;
      font-weight: 700;
      font-size: 1.6rem;
      margin-bottom: 1.5rem;
      border-left: 5px solid #f1c40f;
      padding-left: 14px;
    }
    .form-group { margin-bottom: 18px; display: flex; flex-direction: column; }
    label { font-weight: 600; font-size: 1rem; color: #2c3e50; margin-bottom: 6px; }
    label .required { color: #e74c3c; margin-left: 2px; }
    select, input {
      width: 100%;
      padding: 14px 16px;
      border: 2px solid #dfe6e9;
      border-radius: 14px;
      font-size: 1rem;
      background: #fafafa;
      min-height: 54px;
      -webkit-appearance: none;
      appearance: none;
      transition: 0.2s;
      outline: none;
      font-family: inherit;
    }
    select:focus, input:focus { border-color: #f1c40f; box-shadow: 0 0 0 4px rgba(241, 196, 15, 0.2); }
    select:disabled, input:read-only { background: #f1f2f6; cursor: not-allowed; opacity: 0.8; }
    .new-member-group { display: none; margin-top: 4px; padding-top: 16px; border-top: 2px dashed #dfe6e9; }
    .new-member-group.visible { display: block; }
    #genderDisplay { display: block; }
    #genderSelect { display: none; }
    .editable #genderDisplay { display: none; }
    .editable #genderSelect { display: block; }
    .input-error { border-color: #e74c3c !important; background: #fff5f5 !important; }
    .error-message { color: #e74c3c; font-size: 0.9rem; margin-top: 6px; display: none; font-weight: 500; }
    .error-message.show { display: block; }
    .btn-submit {
      width: 100%;
      padding: 16px;
      background: #f1c40f;
      color: #1a2b3c;
      border: none;
      border-radius: 14px;
      font-size: 1.1rem;
      font-weight: 700;
      cursor: pointer;
      margin-top: 12px;
      box-shadow: 0 4px 12px rgba(241, 196, 15, 0.3);
      min-height: 54px;
      transition: 0.2s;
    }
    .btn-submit:hover:not(:disabled) { background: #d4ac0d; transform: translateY(-2px); }
    .btn-submit:disabled { background: #f9e79f; color: #7d6608; cursor: not-allowed; }
    #message {
      margin-top: 18px;
      padding: 14px;
      border-radius: 12px;
      text-align: center;
      font-weight: 600;
      display: none;
    }
    #message.success { display: block; background: #e8f5e9; color: #2e7d32; border: 1px solid #a5d6a7; }
    #message.error { display: block; background: #ffebee; color: #c62828; border: 1px solid #ef9a9a; }
    #loading-overlay {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(255,255,255,0.8);
      backdrop-filter: blur(4px);
      display: none;
      justify-content: center;
      align-items: center;
      border-radius: 24px;
      flex-direction: column;
      gap: 16px;
      z-index: 999;
    }
    #loading-overlay.show { display: flex; }
    .spinner {
      width: 44px; height: 44px;
      border: 4px solid #e0e0e0;
      border-top: 4px solid #f1c40f;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    .loading-text { font-size: 1rem; color: #2c3e50; font-weight: 500; }
    @media (max-width: 480px) {
      .card { padding: 20px 16px; }
      h2 { font-size: 1.4rem; }
      select, input { padding: 12px 14px; min-height: 48px; }
      .btn-submit { padding: 14px; font-size: 1rem; min-height: 48px; }
    }
    @media (max-width: 360px) {
      .card { padding: 16px 12px; }
      h2 { font-size: 1.2rem; }
      select, input { padding: 10px 12px; min-height: 44px; font-size: 0.95rem; }
      .btn-submit { padding: 12px; font-size: 0.95rem; min-height: 44px; }
    }
  </style>
</head>
<body>

<div class="card">
  <div id="loading-overlay">
    <div class="spinner"></div>
    <div class="loading-text">Loading data…</div>
  </div>

  <h2>📋 Attendance Form</h2>

  <div class="form-group">
    <label for="team">Team <span class="required">*</span></label>
    <select id="team" onchange="onTeamChange()">
      <option value="">-- Select Team --</option>
    </select>
  </div>

  <div class="form-group">
    <label for="member">Member <span class="required">*</span></label>
    <select id="member" onchange="onMemberChange()">
      <option value="">-- Select Member --</option>
    </select>
  </div>

  <div class="new-member-group" id="newMemberGroup">
    <div class="form-group">
      <label for="newMemberName">New Member Name <span class="required">*</span></label>
      <input type="text" id="newMemberName" placeholder="Enter full name">
    </div>
  </div>

  <div class="form-group">
    <label for="phone">Phone <span class="required" id="phoneRequired" style="display:none;">*</span></label>
    <input type="tel" id="phone" readonly inputmode="numeric">
    <div class="error-message" id="phoneError">Phone must be 11 digits starting with 010, 011, 012, or 015.</div>
  </div>

  <div class="form-group">
    <label for="genderDisplay">Gender <span class="required" id="genderRequired" style="display:none;">*</span></label>
    <input type="text" id="genderDisplay" readonly>
    <select id="genderSelect">
      <option value="">-- Select --</option>
      <option value="Male">Male</option>
      <option value="Female">Female</option>
    </select>
    <div class="error-message" id="genderError">Please select a gender.</div>
  </div>

  <div class="form-group">
    <label for="nationalId">National ID <span class="required" id="idRequired" style="display:none;">*</span></label>
    <input type="text" id="nationalId" readonly inputmode="numeric">
    <div class="error-message" id="idError">National ID must be exactly 14 digits.</div>
  </div>

  <button class="btn-submit" id="submitBtn" onclick="submitForm()">Submit</button>

  <div id="message"></div>
</div>

<script>
  // ====== Configuration ======
  const API_URL = 'https://script.google.com/macros/s/AKfycbw95R3TbxLRqz-DX4oXzylzO4vorh1VctNT-jikyZFM2lKb5pDbZW3bw8P8cqRu7P3kWQ/exec';

  // ====== UI helpers (same as before) ======
  function showLoading() {
    document.getElementById('loading-overlay').classList.add('show');
    document.getElementById('team').disabled = true;
    document.getElementById('member').disabled = true;
    document.getElementById('submitBtn').disabled = true;
  }
  function hideLoading() {
    document.getElementById('loading-overlay').classList.remove('show');
    document.getElementById('team').disabled = false;
    document.getElementById('member').disabled = false;
    document.getElementById('submitBtn').disabled = false;
  }
  function showMessage(text, isSuccess = true) {
    const msg = document.getElementById('message');
    msg.textContent = text;
    msg.className = isSuccess ? 'success' : 'error';
    if (isSuccess) setTimeout(() => { msg.style.display = 'none'; }, 5000);
  }
  function hideMessage() {
    const msg = document.getElementById('message');
    msg.style.display = 'none';
    msg.className = '';
  }
  function clearErrors() {
    ['phone', 'genderSelect', 'nationalId'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.classList.remove('input-error');
      const err = document.getElementById(id + 'Error');
      if (err) err.classList.remove('show');
    });
    hideMessage();
  }
  function toggleNewMember(show) {
    const group = document.getElementById('newMemberGroup');
    const phone = document.getElementById('phone');
    const genderDisplay = document.getElementById('genderDisplay');
    const genderSelect = document.getElementById('genderSelect');
    const nationalId = document.getElementById('nationalId');
    const newNameInput = document.getElementById('newMemberName');
    clearErrors();
    if (show) {
      group.classList.add('visible');
      phone.removeAttribute('readonly');
      phone.required = true;
      genderSelect.style.display = 'block';
      genderDisplay.style.display = 'none';
      nationalId.removeAttribute('readonly');
      nationalId.required = true;
      document.getElementById('phoneRequired').style.display = 'inline';
      document.getElementById('genderRequired').style.display = 'inline';
      document.getElementById('idRequired').style.display = 'inline';
      phone.value = '';
      genderSelect.value = '';
      nationalId.value = '';
      newNameInput.value = '';
      newNameInput.focus();
    } else {
      group.classList.remove('visible');
      phone.setAttribute('readonly', 'readonly');
      phone.required = false;
      genderSelect.style.display = 'none';
      genderDisplay.style.display = 'block';
      nationalId.setAttribute('readonly', 'readonly');
      nationalId.required = false;
      document.getElementById('phoneRequired').style.display = 'none';
      document.getElementById('genderRequired').style.display = 'none';
      document.getElementById('idRequired').style.display = 'none';
      newNameInput.value = '';
    }
  }
  function validatePhone(phone) { return /^(010|011|012|015)\d{8}$/.test(phone); }
  function validateNationalId(id) { return /^\d{14}$/.test(id); }
  function validateNewMemberFields() {
    const phone = document.getElementById('phone').value.trim();
    const gender = document.getElementById('genderSelect').value;
    const nationalId = document.getElementById('nationalId').value.trim();
    const newName = document.getElementById('newMemberName').value.trim();
    let isValid = true;
    clearErrors();
    if (!newName) {
      document.getElementById('newMemberName').classList.add('input-error');
      showMessage('Please enter the new member\'s name.', false);
      isValid = false;
    }
    if (!validatePhone(phone)) {
      document.getElementById('phone').classList.add('input-error');
      document.getElementById('phoneError').classList.add('show');
      isValid = false;
    }
    if (!gender) {
      document.getElementById('genderSelect').classList.add('input-error');
      document.getElementById('genderError').classList.add('show');
      isValid = false;
    }
    if (!validateNationalId(nationalId)) {
      document.getElementById('nationalId').classList.add('input-error');
      document.getElementById('idError').classList.add('show');
      isValid = false;
    }
    return isValid;
  }

  // ====== API call ======
  async function callAPI(action, payload = {}) {
    showLoading();
    try {
      const response = await fetch(API_URL, {
        method: 'POST',
        mode: 'cors',                // Now we can read the response
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action, ...payload })
      });
      const result = await response.json();
      hideLoading();
      if (result.success) {
        return result.data || result.message;
      } else {
        showMessage('Error: ' + result.error, false);
        return null;
      }
    } catch (error) {
      hideLoading();
      showMessage('Network error: ' + error.message, false);
      return null;
    }
  }

  // ====== Load teams ======
  async function loadTeams() {
    const teams = await callAPI('getTeams');
    if (teams) {
      const teamSelect = document.getElementById('team');
      teams.forEach(team => {
        const opt = document.createElement('option');
        opt.value = team;
        opt.text = team;
        teamSelect.appendChild(opt);
      });
    }
  }

  // ====== Team change ======
  async function onTeamChange() {
    const teamSelect = document.getElementById('team');
    const memberSelect = document.getElementById('member');
    const team = teamSelect.value;
    memberSelect.innerHTML = '<option value="">-- Select Member --</option>';
    document.getElementById('phone').value = '';
    document.getElementById('genderDisplay').value = '';
    document.getElementById('genderSelect').value = '';
    document.getElementById('nationalId').value = '';
    hideMessage();
    toggleNewMember(false);
    if (!team) return;

    const members = await callAPI('getMembers', { team });
    if (members) {
      members.forEach(member => {
        const opt = document.createElement('option');
        opt.value = member;
        opt.text = member;
        memberSelect.appendChild(opt);
      });
      const newOpt = document.createElement('option');
      newOpt.value = '__new__';
      newOpt.text = '+ Add New Member';
      memberSelect.appendChild(newOpt);
    }
  }

  // ====== Member change ======
  async function onMemberChange() {
    const memberSelect = document.getElementById('member');
    const member = memberSelect.value;
    hideMessage();
    if (member === '__new__') {
      toggleNewMember(true);
      return;
    }
    toggleNewMember(false);
    if (!member) {
      document.getElementById('phone').value = '';
      document.getElementById('genderDisplay').value = '';
      document.getElementById('genderSelect').value = '';
      document.getElementById('nationalId').value = '';
      return;
    }
    const details = await callAPI('getDetails', { member });
    if (details) {
      document.getElementById('phone').value = details.phone || '';
      document.getElementById('genderDisplay').value = details.gender || '';
      document.getElementById('genderSelect').value = details.gender || '';
      document.getElementById('nationalId').value = details.nationalId || '';
    }
  }

  // ====== Submit form ======
  async function submitForm() {
    const team = document.getElementById('team').value;
    const memberSelect = document.getElementById('member');
    let member = memberSelect.value;
    let phone = document.getElementById('phone').value.trim();
    let gender = document.getElementById('genderSelect').value;
    let nationalId = document.getElementById('nationalId').value.trim();

    if (member === '__new__') {
      if (!validateNewMemberFields()) return;
      const newName = document.getElementById('newMemberName').value.trim();
      member = newName;
    } else {
      phone = document.getElementById('phone').value.trim();
      gender = document.getElementById('genderDisplay').value.trim();
      nationalId = document.getElementById('nationalId').value.trim();
      if (!member) {
        showMessage('Please select a member or choose "+ Add New Member".', false);
        return;
      }
    }
    if (!team) {
      showMessage('Please select a team.', false);
      return;
    }

    const result = await callAPI('save', { team, member, phone, gender, nationalId });
    if (result) {
      showMessage('✅ Attendance recorded!', true);
      // Reset form
      document.getElementById('team').value = '';
      document.getElementById('member').innerHTML = '<option value="">-- Select Member --</option>';
      document.getElementById('phone').value = '';
      document.getElementById('genderDisplay').value = '';
      document.getElementById('genderSelect').value = '';
      document.getElementById('nationalId').value = '';
      toggleNewMember(false);
      document.getElementById('newMemberName').value = '';
    }
  }

  // ====== Init ======
  window.onload = loadTeams;
</script>
</body>
</html>
